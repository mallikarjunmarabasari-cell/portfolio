# Local backend environment settings
NODE_ENV=development
PORT=3000

# Gmail account used to send portfolio contact emails
# Use an app password generated in Google Account security settings.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Optional: Gmail sender/recipient. Defaults to GMAIL_USER if not provided.
MAIL_SENDER=you@gmail.com
MAIL_RECIPIENT=you@gmail.com
